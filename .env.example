# Docker compose Postgres defaults
POSTGRES_USER=kirimailadmin
POSTGRES_PASSWORD=kirimailpassword
POSTGRES_DB=kirimail

# App/ORM connection
DATABASE_URL=postgresql://kirimailadmin:kirimailpassword@localhost:5432/kirimail

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace_with_a_32_plus_char_random_secret
