# Docker compose Postgres defaults
POSTGRES_USER=inbokadmin
POSTGRES_PASSWORD=inbokpassword
POSTGRES_DB=inbok

# App/ORM connection
DATABASE_URL=postgresql://inbokadmin:inbokpassword@localhost:5432/inbok

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace_with_a_32_plus_char_random_secret
